<%- include('partials/shell-start', { title: 'HTML / SVG 片段' }) %>
<%- include('partials/site-bar') %>
<main id="main" class="main main--narrow">
  <% if (typeof error !== "undefined" && error) { %>
  <p class="alert alert--err" role="alert"><%= error %></p>
  <% } else { %>
  <h1 class="page-title">已生成片段</h1>
  <label class="field-label">HTML（&lt;img&gt;）</label>
  <textarea class="code" readonly rows="4"><%= htmlSnippet %></textarea>
  <label class="field-label">SVG</label>
  <textarea class="code" readonly rows="10"><%= svgSnippet %></textarea>
  <% } %>
  <p class="back-row"><a class="btn btn--ghost" href="/">← 返回工作台</a></p>
</main>
<%- include('partials/shell-end', { loadEnhance: false }) %>
