<%- include('partials/shell-start', { title: '已生成 Base64' }) %>
<%- include('partials/site-bar') %>
<main id="main" class="main main--narrow">
  <% if (typeof error !== "undefined" && error) { %>
  <p class="alert alert--err" role="alert"><%= error %></p>
  <% } else { %>
  <h1 class="page-title">图片已转为 Base64</h1>
  <p class="muted">可复制下方内容；也可 <a href="<%- dataUrl %>" download="image.<%= ext %>">下载图片</a>。</p>
  <label class="field-label">Data URL</label>
  <textarea class="code" readonly rows="8"><%= dataUrl %></textarea>
  <label class="field-label">纯 Base64</label>
  <textarea class="code" readonly rows="6"><%= rawBase64 %></textarea>
  <% } %>
  <p class="back-row"><a class="btn btn--ghost" href="/">← 返回工作台</a></p>
</main>
<%- include('partials/shell-end', { loadEnhance: false }) %>
