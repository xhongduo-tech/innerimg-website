<% var fname = typeof fieldName !== "undefined" ? fieldName : "file"; %>
        <label class="upload-zone" data-dropzone>
          <input type="file" class="upload-zone__input" name="<%= fname %>" accept="image/*" required />
          <div class="upload-zone__inner">
            <span class="upload-zone__icon" aria-hidden="true">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            </span>
            <span class="upload-zone__title">拖放图片到此处</span>
            <span class="upload-zone__hint">或 <em>点击区域选择文件</em></span>
            <span class="upload-zone__filename" data-filename hidden></span>
          </div>
        </label>
