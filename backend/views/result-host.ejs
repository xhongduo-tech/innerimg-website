<%- include('partials/shell-start', { title: '临时链接已生成' }) %>
<%- include('partials/site-bar') %>
<main id="main" class="main main--narrow">
  <% if (typeof error !== "undefined" && error) { %>
  <p class="alert alert--err" role="alert"><%= error %></p>
  <% } else { %>
  <h1 class="page-title">链接已生成</h1>
  <p class="muted">过期时间：<strong><%= expiresText %></strong></p>
  <div class="url-box">
    <a href="<%- absoluteUrl %>" target="_blank" rel="noopener noreferrer"><%= absoluteUrl %></a>
  </div>
  <div class="preview-box">
    <img src="<%- absoluteUrl %>" alt="托管图" />
  </div>
  <% } %>
  <p class="back-row"><a class="btn btn--ghost" href="/">← 返回工作台</a></p>
</main>
<%- include('partials/shell-end', { loadEnhance: false }) %>
