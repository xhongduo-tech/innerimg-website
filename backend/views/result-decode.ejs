<%- include('partials/shell-start', { title: '已解码图片' }) %>
<%- include('partials/site-bar') %>
<main id="main" class="main main--narrow">
  <% if (typeof error !== "undefined" && error) { %>
  <p class="alert alert--err" role="alert"><%= error %></p>
  <% } else { %>
  <h1 class="page-title">解码成功</h1>
  <div class="preview-box">
    <img src="<%- dataUrl %>" alt="解码图像" />
  </div>
  <p><a class="btn btn--primary" href="<%- dataUrl %>" download="decoded.<%= ext %>">下载图片</a></p>
  <% } %>
  <p class="back-row"><a class="btn btn--ghost" href="/">← 返回工作台</a></p>
</main>
<%- include('partials/shell-end', { loadEnhance: false }) %>
