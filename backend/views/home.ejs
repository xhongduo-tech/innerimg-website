<%- include('partials/shell-start', { title: '工作台' }) %>
<%- include('partials/site-bar') %>
<%- include('partials/hero') %>
<%- include('partials/nav') %>

<main id="main" class="main">
  <section class="workflow" id="wf-base64" aria-labelledby="h-base64">
    <header class="workflow__intro">
      <span class="workflow__badge">工具 ①</span>
      <h2 id="h-base64" class="workflow__title">图片与 Base64 互转</h2>
      <p class="workflow__desc">一侧上传生成编码，一侧粘贴还原图像。适合接口调试、内联图片与文档粘贴场景。</p>
    </header>

    <div class="workflow__grid workflow__grid--2">
      <article class="card card--lift">
        <h3 class="card__title">图片 → Base64</h3>
        <p class="card__hint">提交后可在新页面或（开启脚本时）下方直接查看 Data URL 与纯 Base64。</p>
        <form
          class="stack stack--stretch"
          method="post"
          action="/form/encode-base64"
          enctype="multipart/form-data"
          data-enhance
          data-api-url="/api/form/encode-base64"
        >
          <%- include('partials/upload-zone') %>
          <button type="submit" class="btn btn--primary btn--block">生成 Base64</button>
        </form>
        <div class="live-out" id="out-encode" hidden>
          <h4 class="live-out__title">本页结果</h4>
          <label class="field-label">Data URL</label>
          <textarea class="code" id="out-encode-dataurl" readonly rows="5"></textarea>
          <label class="field-label">纯 Base64</label>
          <textarea class="code" id="out-encode-raw" readonly rows="4"></textarea>
        </div>
      </article>

      <article class="card card--lift">
        <h3 class="card__title">Base64 → 图片</h3>
        <p class="card__hint">支持完整 <code>data:image/…;base64,…</code>，也支持<strong>仅 Base64 正文</strong>。</p>
        <form
          class="stack stack--stretch"
          method="post"
          action="/form/decode-base64"
          data-enhance
          data-api-url="/api/form/decode-base64"
        >
          <label class="field-label" for="decode-payload">粘贴内容</label>
          <textarea class="code code--tall" id="decode-payload" name="payload" rows="10" required placeholder="data:image/png;base64,..."></textarea>
          <button type="submit" class="btn btn--primary btn--block">解析并预览</button>
        </form>
        <div class="live-out" id="out-decode" hidden>
          <h4 class="live-out__title">本页结果</h4>
          <div class="preview-box">
            <img id="out-decode-img" alt="解码预览" />
          </div>
          <p class="live-out__actions"><a class="btn btn--secondary" id="out-decode-dl" href="#" download>下载图片</a></p>
        </div>
      </article>
    </div>
  </section>

  <section class="workflow" id="wf-html" aria-labelledby="h-html">
    <header class="workflow__intro">
      <span class="workflow__badge">工具 ②</span>
      <h2 id="h-html" class="workflow__title">HTML / SVG 片段</h2>
      <p class="workflow__desc">将图片封装成可粘贴的 <code>&lt;img&gt;</code> 或带 <code>&lt;image&gt;</code> 的 SVG；亦可从片段中还原图像。</p>
    </header>

    <div class="workflow__grid workflow__grid--2">
      <article class="card card--lift">
        <h3 class="card__title">图片 → 片段</h3>
        <form
          class="stack stack--stretch"
          method="post"
          action="/form/html-from-image"
          enctype="multipart/form-data"
          data-enhance
          data-api-url="/api/form/html-from-image"
        >
          <%- include('partials/upload-zone') %>
          <button type="submit" class="btn btn--primary btn--block">生成 HTML 与 SVG</button>
        </form>
        <div class="live-out" id="out-html" hidden>
          <h4 class="live-out__title">本页结果</h4>
          <label class="field-label">HTML</label>
          <textarea class="code" id="out-html-img" readonly rows="3"></textarea>
          <label class="field-label">SVG</label>
          <textarea class="code" id="out-html-svg" readonly rows="8"></textarea>
        </div>
      </article>

      <article class="card card--lift">
        <h3 class="card__title">片段 → 图片</h3>
        <form
          class="stack stack--stretch"
          method="post"
          action="/form/parse-html"
          data-enhance
          data-api-url="/api/form/parse-html"
        >
          <label class="field-label" for="html-payload">粘贴 HTML / SVG 源码</label>
          <textarea class="code code--tall" id="html-payload" name="htmlPayload" rows="12" required placeholder="含 data:image… 或 src/href 的片段"></textarea>
          <button type="submit" class="btn btn--primary btn--block">解析</button>
        </form>
        <div class="live-out" id="out-parse" hidden>
          <h4 class="live-out__title">本页结果</h4>
          <div class="preview-box">
            <img id="out-parse-img" alt="解析预览" />
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="workflow workflow--last" id="wf-host" aria-labelledby="h-host">
    <header class="workflow__intro">
      <span class="workflow__badge">工具 ③</span>
      <h2 id="h-host" class="workflow__title">临时图片 URL</h2>
      <p class="workflow__desc">生成内网可访问的直链，便于大模型或同事拉取；默认 2 小时失效，最长 30 天，到期自动删除。</p>
    </header>

    <article class="card card--lift card--wide">
      <form
        class="stack stack--stretch"
        method="post"
        action="/form/host"
        enctype="multipart/form-data"
        data-enhance
        data-api-url="/api/form/host"
      >
        <%- include('partials/upload-zone') %>
        <div class="host-row">
          <label class="field-inline field-inline--grow">
            <span class="field-label">链接有效时长</span>
            <select name="ttlSeconds" class="select select--wide">
              <option value="7200" selected>2 小时（默认）</option>
              <option value="21600">6 小时</option>
              <option value="86400">24 小时</option>
              <option value="604800">7 天</option>
              <option value="2592000">30 天</option>
            </select>
          </label>
        </div>
        <button type="submit" class="btn btn--primary btn--block">上传并生成链接</button>
      </form>
      <div class="live-out" id="out-host" hidden>
        <h4 class="live-out__title">本页结果</h4>
        <p class="field-label">链接</p>
        <div class="url-box">
          <a id="out-host-link" href="#" target="_blank" rel="noopener noreferrer"></a>
        </div>
        <p class="muted" id="out-host-expires"></p>
        <div class="preview-box">
          <img id="out-host-img" alt="托管预览" />
        </div>
      </div>
    </article>
  </section>
</main>

<%- include('partials/shell-end', { loadEnhance: true }) %>
